node nef.js -h # show help
node nef.js -p -d examples/blog # generate json just to look at
node nef.js -ep -d examples/blog # generate json for example blog
pnpm test # run tests
python3 -m http.server 8080 --bind 0.0.0.0 --directory examples/blog # start the server (access on LAN at http://<your-ip>:8080)
open https://github.com/secretGeek/ok-bash # open the doc for the ok script
